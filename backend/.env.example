# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development

# ── Database (Supabase direct connection) ────────────────────────────────────
# Find in: Supabase dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Supabase ─────────────────────────────────────────────────────────────────
# Find in: Supabase dashboard → Settings → API
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Service role key (NOT anon key)

# ── Meta / WhatsApp Cloud API ────────────────────────────────────────────────
# App secret: Meta for Developers → Your App → Settings → Basic → App Secret
META_APP_SECRET=your_meta_app_secret
# Verify token: any string you choose — enter the same value in Meta webhook config
META_VERIFY_TOKEN=your_webhook_verify_token

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-haiku-4-5-20251001

# ── Auth ─────────────────────────────────────────────────────────────────────
# Find in: Supabase dashboard → Settings → API → JWT Settings → JWT Secret
JWT_SECRET=your_supabase_jwt_secret

# ── Wallet ───────────────────────────────────────────────────────────────────
# Credits deducted per new 24-hour conversation window (default: 1)
CONVERSATION_CREDIT_COST=1
